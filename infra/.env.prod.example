# Copy to .env.prod on the VM, fill in real values, and NEVER commit the
# filled-in version (.env.prod is gitignored — see infra/.gitignore).

GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# Neon connection strings — same shieldstream_app/shieldstream_worker roles
# as local dev (see neon-notes.md), just pointed at your Neon branch instead
# of the compose postgres service. Two different URL schemes for the SAME
# shieldstream_worker role: gateway's admin route uses SQLAlchemy's async
# driver (+asyncpg), the consumers use asyncpg directly (plain postgresql://)
# — matching the scheme each already uses locally (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://shieldstream_app:REPLACE_ME@<neon-host>/shieldstream?ssl=require
ADMIN_DATABASE_URL=postgresql+asyncpg://shieldstream_worker:REPLACE_ME@<neon-host>/shieldstream?ssl=require
WORKER_DATABASE_URL=postgresql://shieldstream_worker:REPLACE_ME@<neon-host>/shieldstream?sslmode=require

GRAFANA_ADMIN_PASSWORD=REPLACE_ME
