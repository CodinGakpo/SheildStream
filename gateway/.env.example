# Copy to .env for local, non-Docker-Compose runs. Docker Compose sets these
# directly as container environment variables (see docker-compose.yml); this
# file exists for reference and for running the gateway outside Compose.
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://shieldstream_app:localdev_only@localhost:5432/shieldstream
LOG_LEVEL=debug
RATE_LIMIT_FAIL_OPEN=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
